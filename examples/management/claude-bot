#!/usr/bin/env bash
# claude-bot — Manage Claude Code Telegram bot fleet
# Usage: claude-bot {start|stop|restart|status|logs} {bot-name|all}
#
# CONFIGURE: Edit the bot definitions below to match your fleet.
# Each bot needs a tmux session name, socket name, and start script path.

set -euo pipefail

# ============================================================
# BOT DEFINITIONS — customize for your fleet
# ============================================================
declare -A BOT_TMUX BOT_SOCKET BOT_SCRIPT

# Bot 1: Chief of Staff (email, calendar, admin)
BOT_TMUX[cos]="claude-cos-bot"
BOT_SOCKET[cos]="claude-cos"
BOT_SCRIPT[cos]="$HOME/bin/claude-cos-bot-start.sh"

# Bot 2: VP Engineering — Project A
BOT_TMUX[vpe-a]="claude-vpe-a-bot"
BOT_SOCKET[vpe-a]="claude-vpe-a"
BOT_SCRIPT[vpe-a]="$HOME/bin/claude-vpe-a-bot-start.sh"

# Bot 3: VP Engineering — Project B
BOT_TMUX[vpe-b]="claude-vpe-b-bot"
BOT_SOCKET[vpe-b]="claude-vpe-b"
BOT_SCRIPT[vpe-b]="$HOME/bin/claude-vpe-b-bot-start.sh"

# Bot 4: CTO (cross-project architecture)
BOT_TMUX[cto]="claude-cto-bot"
BOT_SOCKET[cto]="claude-cto"
BOT_SCRIPT[cto]="$HOME/bin/claude-cto-bot-start.sh"

# Bot 5: DevOps (fleet management)
BOT_TMUX[devops]="claude-devops-bot"
BOT_SOCKET[devops]="claude-devops"
BOT_SCRIPT[devops]="$HOME/bin/claude-devops-bot-start.sh"

# Bot 6: Product Marketing (research, content)
BOT_TMUX[marketing]="claude-marketing-bot"
BOT_SOCKET[marketing]="claude-marketing"
BOT_SCRIPT[marketing]="$HOME/bin/claude-marketing-bot-start.sh"

# Add more bots by copying the pattern above

# Space-separated list of all bot names (must match keys above)
ALL_BOTS="cos vpe-a vpe-b cto devops marketing"

# ============================================================
# COMMANDS — generally no changes needed below
# ============================================================

start_bot() {
    local name="$1"
    local session="${BOT_TMUX[$name]}"
    local socket="${BOT_SOCKET[$name]}"
    local script="${BOT_SCRIPT[$name]}"

    if tmux -L "$socket" has-session -t "$session" 2>/dev/null; then
        echo "$name bot already running"
        return 0
    fi

    tmux -L "$socket" new-session -d -s "$session" "$script"
    echo "$name bot started"
}

stop_bot() {
    local name="$1"
    local session="${BOT_TMUX[$name]}"
    local socket="${BOT_SOCKET[$name]}"

    if ! tmux -L "$socket" has-session -t "$session" 2>/dev/null; then
        echo "$name bot not running"
        return 0
    fi

    # Send Ctrl+C first for graceful shutdown, then kill the session
    tmux -L "$socket" send-keys -t "$session" C-c
    sleep 2
    tmux -L "$socket" kill-session -t "$session" 2>/dev/null || true
    echo "$name bot stopped"
}

status_bot() {
    local name="$1"
    local session="${BOT_TMUX[$name]}"
    local socket="${BOT_SOCKET[$name]}"

    if tmux -L "$socket" has-session -t "$session" 2>/dev/null; then
        echo "$name bot: RUNNING"
    else
        echo "$name bot: STOPPED"
    fi
}

logs_bot() {
    local name="$1"
    local session="${BOT_TMUX[$name]}"
    local socket="${BOT_SOCKET[$name]}"

    if ! tmux -L "$socket" has-session -t "$session" 2>/dev/null; then
        echo "$name bot not running"
        return 1
    fi

    echo "Attaching to $name bot. Press Ctrl+B then D to detach."
    tmux -L "$socket" attach-session -t "$session"
}

resolve_targets() {
    local target="${1:-all}"
    if [ "$target" = "all" ]; then
        echo "$ALL_BOTS"
        return
    fi
    # Validate bot name exists
    if [ -z "${BOT_TMUX[$target]+x}" ]; then
        echo "Unknown bot: $target" >&2
        echo "Available bots: $ALL_BOTS" >&2
        exit 1
    fi
    echo "$target"
}

ACTION="${1:-status}"
TARGET="${2:-all}"

case "$ACTION" in
    start)   for bot in $(resolve_targets "$TARGET"); do start_bot "$bot"; done ;;
    stop)    for bot in $(resolve_targets "$TARGET"); do stop_bot "$bot"; done ;;
    restart) for bot in $(resolve_targets "$TARGET"); do stop_bot "$bot"; sleep 1; start_bot "$bot"; done ;;
    status)  for bot in $(resolve_targets "$TARGET"); do status_bot "$bot"; done ;;
    logs)
        [[ "$TARGET" == "all" ]] && { echo "Specify which bot: $ALL_BOTS"; exit 1; }
        logs_bot "$TARGET" ;;
    *) echo "Usage: claude-bot {start|stop|restart|status|logs} {bot-name|all}"; exit 1 ;;
esac
